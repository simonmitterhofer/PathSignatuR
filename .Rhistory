usethis::use_mit_license("Simon Mitterhofer")
usethis::use_rcpp()
usethis::use_package_doc()      # creates R/PathSignatuR-package.R
usethis::use_rcpp()
usethis::use_testthat(3)
pkgbuild::check_build_tools()
Sys.which("make")
usethis::use_r("enumerateWords")        # opens R/enumerateWords.R
usethis::use_test("enumerateWords")     # opens tests/testthat/test-enumerateWords.R
devtools::load_all()
enumerateWords(2, 2)        # sanity check
enumerateWords(3, 0)        # just integer(0)
enumerateWords(2, 3)        # 1 + 2 + 4 + 8 = 15 words
devtools::test_active_file()    # or Ctrl+Shift+T with the test file open
usethis::use_r("reference")
devtools::load_all()
# 1D linear path: signature term at level k = (b - a)^k / k!
x <- seq(0, 2, length.out = 100)
PathSignatuR:::.signatureRef(x, 4)
2^(0:4) / factorial(0:4)        # should match
devtools::load_all()
x <- seq(0, 2, length.out = 100)
PathSignatuR:::.signatureRef(x, 4)
2^(0:4) / factorial(0:4)
usethis::use_test("reference")
devtools::test_active_file()
pkgbuild::check_build_tools()
usethis::use_cpp_function()
Rcpp::compileAttributes()   # regenerates R/RcppExports.R + src/RcppExports.cpp
devtools::load_all()        # compiles and loads
# Sanity check 1: 1D linear path, closed form
x <- seq(0, 2, length.out = 100)
PathSignatuR:::sig_terminal_cpp(matrix(x, ncol = 1), 4L)
devtools::load_all()
PathSignatuR:::sig_terminal_cpp(matrix(seq(0, 2, length.out = 100), ncol = 1), 4L)
devtools::clean_dll()
load_all()
devtools::clean_dll()
devtools::load_all()
PathSignatuR:::sig_terminal_cpp(matrix(seq(0, 2, length.out = 100), ncol = 1), 4L)
devtools::document()
devtools::load_all()
PathSignatuR:::sig_terminal_cpp(matrix(seq(0, 2, length.out = 100), ncol = 1), 4L)
X <- matrix(rnorm(60), 30, 2)
all.equal(PathSignatuR:::sig_terminal_cpp(X, 3L),
PathSignatuR:::.signatureRef(X, 3))
devtools::document()
devtools::load_all()
# Quickstart sanity check
X <- matrix(rnorm(60), 30, 2)
signature(X, depth = 2)
signature(X, depth = 2, includeLevelZero = FALSE)
signature(X, depth = 2, sep = "")
devtools::document()
devtools::load_all()
# Quickstart sanity check
X <- matrix(rnorm(60), 30, 2)
signature(X, depth = 2)
signature(X, depth = 2, includeLevelZero = FALSE)
signature(X, depth = 2, sep = "")
devtools::document()
devtools::load_all()
# Quickstart sanity check
X <- matrix(rnorm(60), 30, 2)
signature(X, depth = 2)
signature(X, depth = 2, includeLevelZero = FALSE)
signature(X, depth = 2, sep = "")
usethis::use_test("signature")
devtools::test_active_file()
devtools::test_active_file()
usethis::use_r("timeAugment")
usethis::use_test("timeAugment")
devtools::document()
devtools::test()    # full suite this time
devtools::document()
devtools::test()    # full suite this time
devtools::check()
devtools::document()
devtools::check()
git add -A
Rcpp::compileAttributes()
devtools::load_all()
devtools::test()
PathSignatuR:::sig_batch_cpp(list(matrix(rnorm(20), 10, 2),
matrix(rnorm(30), 15, 2)), 2L)
PathSignatuR:::sig_path_cpp(matrix(rnorm(20), 10, 2), 2L)
usethis::use_dev_version()
usethis::use_dev_version()
devtools::document()
devtools::load_all()
# signatureBatch sanity
paths <- list(
a = matrix(rnorm(40), 20, 2),
b = matrix(rnorm(60), 30, 2)
)
signatureBatch(paths, depth = 2)
# 3D array dispatch
arr <- array(rnorm(60), dim = c(10, 2, 3))
signatureBatch(arr, depth = 2)
# signaturePath sanity
X <- matrix(cumsum(rnorm(40)), 20, 2)
sp <- signaturePath(X, depth = 2)
sp[1, ]                                   # all zeros except [1] = 1
all.equal(sp[20, ], signature(X, depth = 2))   # matches terminal
usethis::use_test("signatureBatch")
usethis::use_test("signaturePath")
devtools::document()
devtools::test()
devtools::document()
devtools::test()
devtools::document()
devtools::check()
